<Layouts.app flash={@flash} current_scope={@current_scope}>
  <.header>
    Edit Album {@album.id}
    <:subtitle>Use this form to manage album records in your database.</:subtitle>
  </.header>

  <.album_form
    changeset={@changeset}
    action={~p"/albums/#{@album}"}
    return_to={~p"/albums"}
  />
</Layouts.app>
